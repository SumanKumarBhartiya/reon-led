# Copy this to .env and fill in values

# When you have a real backend:
# VITE_API_URL=https://api.your-domain.com

# For Formspree (free form service for GitHub Pages):
# 1. Sign up at https://formspree.io
# 2. Create a form and paste the ID here
# VITE_FORMSPREE_ID=your_form_id_here

# If neither is set, the contact form opens the user's email client (mailto fallback)
